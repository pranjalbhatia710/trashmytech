# Backend environment variables
# Copy this to .env: cp .env.example .env

# REQUIRED — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Analysis mode: "lite" (free, local checks) or "full" (paid Google APIs)
ANALYSIS_MODE=lite

# Browser settings
HEADLESS=true
AGENT_COUNT=12
NUM_BROWSERS=5

# Database (optional — app works without it)
# DATABASE_URL=postgresql://user:pass@host:5432/trashmytech

# Redis cache (optional — app works without it)
# REDIS_URL=redis://default:token@host:6379

# Auth (optional — needed for user accounts)
# JWT_SECRET=generate-with-openssl-rand-base64-32

# Stripe (optional — needed for payments)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Google APIs (optional — only for ANALYSIS_MODE=full)
# GOOGLE_API_KEY=your-google-api-key
